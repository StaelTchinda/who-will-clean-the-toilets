# Copy this file to .env and fill in the values for the backend you've chosen.
# The .env file is gitignored and must never be committed.

# --- Backend selection -------------------------------------------------------
# Which storage backend the app talks to. "supabase" (default) uses Postgres +
# Realtime; "cloudflare" uses Cloudflare D1 over HTTP with polling. Inlined at
# build time by Vite (must start with VITE_).
VITE_BACKEND=supabase

# --- Supabase (only needed when VITE_BACKEND=supabase) -----------------------
# Client-side (Vite inlines VITE_* vars into the browser bundle).
# Safe to expose publicly; the anon/publishable key is protected by RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_PROJECT_ID=

# Server-side (SSR fallback; not exposed to the browser).
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Server-only secret — NEVER prefix this with VITE_ or it will leak into the client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare D1 (only needed when VITE_BACKEND=cloudflare) ----------------
# Override the API base URL the browser talks to. Defaults to same-origin
# (/api/cf), which is what the worker serves. Set this only if you front the
# worker behind a custom domain or run the API on a separate host in dev.
# VITE_CF_API_BASE=/api/cf
#
# Cloudflare credentials for `wrangler deploy` are NOT read from .env — they
# live in GitHub Actions secrets / your shell env:
#   CLOUDFLARE_ACCOUNT_ID
#   CLOUDFLARE_API_TOKEN
#   CLOUDFLARE_D1_DATABASE_ID
