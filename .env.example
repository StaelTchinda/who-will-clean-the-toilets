# Supabase configuration
# Copy this file to .env and fill in the values from your Supabase project settings.
# The .env file is gitignored and must never be committed.

# --- Client-side (Vite inlines VITE_* vars into the browser bundle) ---
# These are safe to expose publicly; the anon/publishable key is protected by Row-Level Security.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_PROJECT_ID=

# --- Server-side (SSR fallback; not exposed to the browser) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Server-only secret — NEVER prefix this with VITE_ or it will leak into the client bundle.
SUPABASE_SERVICE_ROLE_KEY=
